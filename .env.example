# Copy to ".env" (or ".env.local") in your Vite project root — the same
# folder that has package.json / vite.config.js — NOT inside src/.

# Must match wherever the backend is running + the /api prefix used in app.js
VITE_API_URL=http://localhost:5000/api

# Must be false (or removed) once the real backend above is running.
# When true, BookerLogin.jsx and ChangePasswordModal.jsx skip the backend
# entirely and fake a successful login/password change.
VITE_DEV_LOGIN=false
