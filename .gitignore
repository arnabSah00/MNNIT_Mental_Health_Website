*.njsproj
*.sln
*.sw?
Thumbs.db

# Vite cache
.vite/

# IMPORTANT: do NOT ignore images — they must be committed so the
# hosted build can bundle them. (No image extensions are listed above,
# so jpg/png/jpeg in src/assets/ are tracked normally.)